# === PawBase theme ===
# 3 presets: terracotta | forest | navy
# Or 'custom' + individual PAW_COLOR_* vars below.
PAW_THEME=terracotta

# Custom theme overrides (only used when PAW_THEME=custom):
# PAW_COLOR_PRIMARY=#C04A2A
# PAW_COLOR_PRIMARY_INK=#FFF7F1
# PAW_COLOR_ACCENT=#E8A33D
# PAW_COLOR_ACCENT_INK=#1A1A1A
# PAW_COLOR_SURFACE=#FAF6F0
# PAW_COLOR_SURFACE_MUTED=#F2EAD9
# PAW_COLOR_SURFACE_CARD=#FFFFFF
# PAW_COLOR_INK=#1A1A1A
# PAW_COLOR_INK_MUTED=#5B554E
# PAW_COLOR_BORDER=#E5DCC9

# === ntfy.sh form delivery ===
# Client-side POST from the contact + book forms.
PUBLIC_NTFY_ENABLED=true
PUBLIC_NTFY_SERVER=https://ntfy.sh
PUBLIC_NTFY_TOPIC=pawbase-form-x7k9p2
