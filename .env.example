# === Site config ===
NEXT_PUBLIC_BRAND=Microsmiles Dental Care
NEXT_PUBLIC_SITE_URL=https://microsmiles-demo.vercel.app
NEXT_PUBLIC_PHONE=+91 90437 53438
NEXT_PUBLIC_EMAIL=microsmilesdental@gmail.com
NEXT_PUBLIC_ADDRESS=Ground Floor, AH 11, 4th Ave, Shanthi Colony, Anna Nagar, Chennai, Tamil Nadu 600 040.
NEXT_PUBLIC_HOURS=Mon - Sat: 12pm – 8pm (Sunday Off)

# === Theme ===
# Preset name: terracotta | forest | navy | sand | charcoal | rose | ocean
THEME=terracotta

# === ntfy.sh form delivery ===
# Client-side POST from contact, book, and feedback forms.
# _TOPIC is the base — the app appends "-contact" and "-book" automatically.
# _FEEDBACK_TOPIC is a separate topic for the feedback form.
NEXT_PUBLIC_NTFY_ENABLED=true
NEXT_PUBLIC_NTFY_SERVER=https://ntfy.sh
NEXT_PUBLIC_NTFY_TOPIC=dental-demo-form-x7k9p2
NEXT_PUBLIC_NTFY_FEEDBACK_TOPIC=dental-demo-feedback-x7k9p2

